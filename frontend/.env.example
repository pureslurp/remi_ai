# Leave unset for local dev (Vite proxies /api to localhost:8000).
# For Vercel: set to your public API origin without trailing slash (no /api suffix).
# VITE_API_BASE=https://your-api.example.com

# Public URL of this frontend (no trailing slash). Used at build time so link previews
# (iMessage, Slack, etc.) get absolute og:image / twitter:image URLs. Match your Vercel domain.
# VITE_PUBLIC_SITE_URL=https://reco-pilot.com

# Enterprise / brokerage "Contact sales" mailto on the marketing landing page.
# VITE_SALES_EMAIL=you@yourdomain.com
