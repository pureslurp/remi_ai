# Local (default): at least one provider key for chat (Anthropic is enough to start)
ANTHROPIC_API_KEY=sk-ant-...
# Optional — enable OpenAI / Google models in Client Settings (host holds keys; users pick per client)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Default model IDs when a project has no llm_model set (see backend/config.py)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_CHAT_MODEL=gpt-4o-mini
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# DEFAULT_LLM_PROVIDER=anthropic

# Admin accounts bypass all token quotas (comma-separated emails)
# ADMIN_EMAILS=you@example.com

# Trial / Pro usage (managed hosting — billable units: input + output×OUTPUT_TOKEN_QUOTA_MULTIPLIER)
# TRIAL_MAX_DAYS=14
# TRIAL_MAX_TOKENS=500000
# PRO_INCLUDED_TOKENS_PER_MONTH=3000000
# OUTPUT_TOKEN_QUOTA_MULTIPLIER=3
# MAX_TOKENS=4096
# Pro: false = same cheap models as trial (Haiku / gpt-4o-mini / Flash) for predictable COGS
# PRO_ALLOW_PREMIUM_MODELS=true
# Optional: Stripe checkout or marketing URL returned on quota / trial exhaustion (402 responses)
# UPGRADE_CHECKOUT_URL=https://...

# --- Optional: Supabase Postgres (cloud / multi-device) ---
# Railway: use Session pooler from Supabase Connect (IPv4). Username is postgres.<project_ref>, not plain postgres.
# DATABASE_URL=postgresql://postgres.abcdefghijklmnop:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# --- Optional: Supabase Storage (document binaries in cloud) ---
# SUPABASE_URL=https://PROJECT.supabase.co
# New-format keys (preferred). Create them in Dashboard → Settings → API Keys.
# SUPABASE_SECRET_KEY=sb_secret_...           # backend only — never expose
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_... # safe to ship to the frontend
# Legacy fallback (still accepted while you finish rotating):
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# SUPABASE_STORAGE_BUCKET=project-docs

# --- Optional: Google OAuth (web app; use with cloud API + Vercel) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Local Vite default (must match GCP "Authorized redirect URIs"):
# GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
# GOOGLE_REDIRECT_URI=https://YOUR_API_HOST/api/auth/google/callback
# FRONTEND_ORIGIN: cloud API must send the browser here after OAuth (usually your Vercel origin).
# For ./run.sh on this machine, use http://localhost:5173 or omit FRONTEND_ORIGIN — if it is
# only set to Vercel while GOOGLE_REDIRECT_URI stays on localhost, you would land on prod without a dev cookie.
# FRONTEND_ORIGIN=https://YOUR_VERCEL_APP.vercel.app
# CORS_ORIGINS=https://YOUR_VERCEL_APP.vercel.app,http://localhost:5173
# Optional: regex for extra browser origins (Vercel previews), e.g. https://your-app[-\w]*\.vercel\.app
# CORS_ORIGIN_REGEX=

# --- Multi-tenant session (required on Postgres + Google web OAuth) ---
# Long random string; signs HttpOnly session cookie after Google login. Not required for SQLite-only local dev.
# SESSION_SECRET=

# --- Local data dir (optional; default ~/.reco/) ---
# RECO_HOME=~/.reco

# --- API debugging (Railway / local): extra fields on GET /api/health ---
# RECO_DEBUG=1
# Legacy names still read by the backend:
# KOVA_DEBUG=1
# REMIP_DEBUG=1

# --- OAuth debugging: JSON error bodies on /api/auth/google/callback + richer reco.auth logs ---
# RECO_AUTH_DEBUG=1
